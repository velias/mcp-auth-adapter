# --- Required ---

# Public base URL of this proxy (used to build registration_endpoint and authorization_endpoint in well-known docs) accessed by MCP Clients
MCP_BASE_URL=http://localhost:3000

# Issuer URL of the upstream IdP (e.g. Keycloak: https://sso.company.com/auth/realms/external, Auth0: https://tenant.auth0.com, Okta: https://org.okta.com/oauth2/default); discovery is attempted via /.well-known/openid-configuration then /.well-known/oauth-authorization-server (RFC 8414)
MCP_UPSTREAM_SSO_URL=https://sso.company.com/auth/realms/external

# OAuth client_id returned by the DCR endpoint (POST /register); setting this enables the DCR proxy.
# Must be pre-registered at the upstream IdP. If omitted, the DCR endpoint is not mounted
# and the upstream IdP's registration endpoint is announced directly if present.
MCP_PROXY_DCR_CLIENT_ID=mcp-client

# --- Optional (defaults shown) ---

# Port the proxy listens on
MCP_PORT=3000

# Comma-separated list of scopes to advertise in the well-known scopes_supported field; if empty, scopes_supported is omitted
MCP_WELL_KNOWN_SCOPES_SUPPORTED=

# Comma-separated scopes to strip from the authorization request before forwarding to upstream.
# Setting this (or MCP_PROXY_AUTH_SCOPES_PRESERVED, or CIMD config) auto-enables the /authorize proxy;
# when none of these are configured, the upstream IdP's authorization endpoint is used directly.
MCP_PROXY_AUTH_SCOPES_REMOVED=offline_access

# Comma-separated scopes to allow in the authorization request; all others are stripped.
# Takes precedence over MCP_PROXY_AUTH_SCOPES_REMOVED if both are set.
MCP_PROXY_AUTH_SCOPES_PRESERVED=

# How often (in minutes) to re-fetch the upstream well-known document; on failure the previous document is kept
MCP_WELL_KNOWN_REFRESH_MINUTES=60

# Enable Prometheus metrics endpoint (GET /metrics) and request instrumentation
# MCP_METRICS_ENABLED=true

# Enable debug-level structured logging
MCP_DEBUG=false

# Graceful shutdown timeout in seconds; if in-flight requests are not drained within
# this period after SIGTERM/SIGINT, the process exits with code 1
# MCP_SHUTDOWN_TIMEOUT_SECONDS=30

# --- CIMD Adapter (EXPERIMENTAL) ---
# Client ID Metadata Document support per draft-ietf-oauth-client-id-metadata-document-01.
# CIMD auto-enables when MCP_PROXY_CIMD_MAP is non-empty or MCP_PROXY_CIMD_DEFAULT_CLIENT_ID is set. auto-enables the /authorize proxy.

# JSON object mapping CIMD URLs to upstream IdP client_ids. Multiple CIMD URLs can map to the same upstream client.
# Format: {"<cimd_url>": "<upstream_client_id>", ...}
# MCP_PROXY_CIMD_MAP={"https://cursor.com/.well-known/oauth-client.json":"cursor-sso-client","https://claude.ai/.well-known/oauth-client.json":"claude-sso-client"}

# Fallback upstream client_id for CIMD URLs not in the map. If unset, unknown CIMD URLs are rejected (strict allowlist).
# MCP_PROXY_CIMD_DEFAULT_CLIENT_ID=

# Cache TTL (in minutes) for validated CIMD metadata documents
# MCP_PROXY_CIMD_CACHE_MINUTES=30
